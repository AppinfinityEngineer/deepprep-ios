{
  "expo": {
    "name": "DeepPrep",
    "slug": "deepprep",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "deepprep",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#050505",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.thoughtsnaplabs.deepprep",
      "infoPlist": {
        "UIBackgroundModes": []
      },
      "buildNumber": "5",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.thoughtsnaplabs.deepprep",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#050505"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#050505"
        }
      ],
      "react-native-iap"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0caee1af-284b-4517-a7e7-4d83f7b3c4b7"
      }
    }
  }
}
